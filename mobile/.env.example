# FastAPI game server (no trailing slash).
# iOS simulator / web: http://127.0.0.1:8000
# Android emulator: http://10.0.2.2:8000
#
# Physical iPhone/Android: set this to 1 so the API host matches Expo Metro (same IP as the QR code).
# Fixes "request timed out" when your PC's LAN IP changed but this file was stale.
EXPO_PUBLIC_API_FOLLOW_METRO=1
#
# Optional explicit URL (used when FOLLOW_METRO is 0, or on web). Example:
# EXPO_PUBLIC_API_URL=http://192.168.1.50:8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
